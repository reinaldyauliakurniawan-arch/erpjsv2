# ============================================================
# ERP Just Speak — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in real values.
# For production, NEVER commit .env — use secrets manager or environment injection.
# ============================================================

APP_NAME="ERP Just Speak"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode driver: "file" (single-instance) or "database" (multi-instance).
# For production with multiple workers, use "database" so maintenance mode is shared.
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Number of PHP CLI server workers (dev only — production uses php-fpm or octane).
# PHP_CLI_SERVER_WORKERS=4

# Bcrypt rounds — higher = more secure but slower. 12 is a good balance.
# Production may bump to 14-16 if CPU budget allows.
BCRYPT_ROUNDS=12

# ============================================================
# Logging
# ============================================================
# Stack routes to comma-separated channels.
# Production: LOG_STACK=daily,stderr (file + container stdout)
# Local dev:  LOG_STACK=single
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Daily log retention (days)
LOG_DAILY_DAYS=30

# Include stacktraces in JSON logs (false in prod, true in dev)
LOG_STACKTRACES=false

# ============================================================
# Database
# ============================================================
# Production: use MySQL or PostgreSQL (NOT SQLite — SQLite is for dev only)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_just_speak
DB_USERNAME=root
DB_PASSWORD=

# For SQLite (dev only):
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# ============================================================
# Session, Cache, Queue
# ============================================================
# Session: "database" (default, multi-instance safe) or "redis" (faster)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache: "database" (default) or "redis" (recommended for production)
CACHE_STORE=database
# CACHE_PREFIX=

# Queue: "database" (default) or "redis" (recommended for production)
# Async jobs (imports, exports, notifications) require a queue worker running.
# Start with: php artisan queue:work --queue=default,imports --tries=3 --backoff=10,30,90
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

# ============================================================
# Redis (optional — recommended for production cache & queue)
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# Mail
# ============================================================
# Production: use SMTP or a service like Mailgun, SES, Postmark.
# Dev: "log" writes emails to laravel.log
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@justspeak.example"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# File Storage (for uploads, exports, imports)
# ============================================================
# Local disk for dev. For production multi-instance, use S3 or similar
# so all workers see the same files.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# Rate Limiting
# ============================================================
# Login attempts per minute per IP
LOGIN_RATE_LIMIT=5
# API rate limit (requests per minute per IP)
API_RATE_LIMIT=60

# ============================================================
# Frontend
# ============================================================
VITE_APP_NAME="${APP_NAME}"
